{
	"name": "eventtrashbox",
	"version": "1.0.0",
	"description": "A custom WordPress theme for EventTrashBox.",
	"author": "Seth Tipton",
	"license": "GPL-2.0-or-later",
	"packageManager": "npm@11.7.0",
	"keywords": [
		"WordPress",
		"Theme",
		"EventTrashBox"
	],
	"homepage": "https://github.com/sethtipton/eventtrashbox#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/sethtipton/eventtrashbox.git"
	},
	"bugs": {
		"url": "https://github.com/sethtipton/eventtrashbox/issues"
	},
	"devDependencies": {
		"@wordpress/scripts": "^32.2.0",
		"@wordpress/stylelint-config": "^23.38.0",
		"eslint": "9.39.4",
		"prettier": "^3.8.3",
		"rtlcss": "^4.3.0",
		"sass": "^1.96.0",
		"stylelint": "^16.26.1"
	},
	"overrides": {
		"minimatch": "^3.1.5",
		"serialize-javascript": "^7.0.5",
		"webpack-dev-server": "^5.2.4"
	},
	"rtlcssConfig": {
		"options": {
			"autoRename": false,
			"autoRenameStrict": false,
			"blacklist": {},
			"clean": true,
			"greedy": false,
			"processUrls": false,
			"stringMap": []
		},
		"plugins": [],
		"map": false
	},
	"scripts": {
		"setup": "node scripts/dev-doctor.mjs && npm install",
		"doctor": "node scripts/dev-doctor.mjs",
		"dev": "npm run watch",
		"watch": "sass sass/:./ --no-source-map --style=expanded --watch",
		"compile:css": "sass sass/:./ --no-source-map --style=expanded",
		"compile:rtl": "rtlcss style.css style-rtl.css",
		"build": "npm run compile:css && npm run compile:rtl",
		"clean": "rm -f style.css.map",
		"check": "npm run format:check && npm run lint && npm run build",
		"format": "prettier --write \".*.json\" \".github/**/*.{yml,yaml}\" \".vscode/**/*.json\" \"*.{json,md}\" \"*.config.mjs\" \"js/**/*.js\" \"scripts/**/*.mjs\" \"sass/**/*.scss\"",
		"format:check": "prettier --check \".*.json\" \".github/**/*.{yml,yaml}\" \".vscode/**/*.json\" \"*.{json,md}\" \"*.config.mjs\" \"js/**/*.js\" \"scripts/**/*.mjs\" \"sass/**/*.scss\"",
		"lint": "npm run lint:js && npm run lint:scss",
		"lint:fix": "npm run lint:js -- --fix && npm run lint:scss -- --fix",
		"lint:scss": "stylelint \"sass/**/*.scss\"",
		"lint:js": "eslint \"js/**/*.js\" \"scripts/**/*.mjs\"",
		"bundle": "node scripts/bundle-theme.mjs"
	}
}
